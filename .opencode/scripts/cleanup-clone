#!/usr/bin/env bash
set -euo pipefail

# cleanup-clone — Remove an isolated clone
# Usage: cleanup-clone --dir <clone_dir>

CLONE_DIR=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --dir) CLONE_DIR="$2"; shift 2 ;;
        *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
done

if [ -z "$CLONE_DIR" ]; then
    echo "Usage: cleanup-clone --dir <clone_dir>" >&2
    exit 1
fi

if [ ! -d "$CLONE_DIR" ]; then
    echo "[cleanup-clone] Clone $CLONE_DIR does not exist" >&2
    exit 0
fi

if [ ! -d "$CLONE_DIR/.git" ]; then
    echo "[cleanup-clone] ERROR: $CLONE_DIR is not a git clone" >&2
    exit 1
fi

echo "[cleanup-clone] Removing clone at $CLONE_DIR" >&2
rm -rf "$CLONE_DIR"
echo "[cleanup-clone] Clone removed" >&2