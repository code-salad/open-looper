#!/usr/bin/env bash
set -euo pipefail

# scaffold-integration-ci — Create a basic integration test CI workflow
# Usage: scaffold-integration-ci [--path .github/workflows/integration.yml]
#
# Creates a GitHub Actions workflow for integration tests if:
#   - .github/workflows/ directory exists
#   - tests/integration/ directory exists
#   - .github/workflows/integration.yml does NOT already exist
#
# Exit 0: created or already exists
# Exit 1: skipped (conditions not met)
# Exit 2: error

TARGET_PATH="${1:-.github/workflows/integration.yml}"

# Check prerequisites
if [[ ! -d ".github/workflows" ]]; then
    echo "[scaffold-integration-ci] Skipped: .github/workflows/ does not exist" >&2
    exit 1
fi

if [[ ! -d "tests/integration" ]]; then
    echo "[scaffold-integration-ci] Skipped: tests/integration/ does not exist" >&2
    exit 1
fi

if [[ -f "$TARGET_PATH" ]]; then
    echo "[scaffold-integration-ci] Skipped: $TARGET_PATH already exists" >&2
    exit 1
fi

# Detect stack for appropriate workflow
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
STACK_JSON=$("$SCRIPT_DIR/detect-stack" 2>/dev/null || echo '{}')
LANGUAGE=$(echo "$STACK_JSON" | jq -r '.language' 2>/dev/null || echo "none")
PACKAGE_MANAGER=$(echo "$STACK_JSON" | jq -r '.package_manager' 2>/dev/null || echo "npm")

# Build appropriate workflow content
case "$LANGUAGE" in
    typescript|javascript)
        WORKFLOW_CONTENT=$(cat <<'EOF'
name: Integration Tests

on:
  push:
    branches: [main, master]
  pull_request:
    branches: [main, master]

jobs:
  integration:
    name: Integration Tests
    runs-on: ubuntu-latest
    timeout-minutes: 15

    steps:
      - uses: actions/checkout@v4

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'npm'

      - name: Install dependencies
        run: npm ci

      - name: Build
        run: npm run build

      - name: Run integration tests
        run: npm run test:integration
EOF
)
        ;;

    python)
        WORKFLOW_CONTENT=$(cat <<'EOF'
name: Integration Tests

on:
  push:
    branches: [main, master]
  pull_request:
    branches: [main, master]

jobs:
  integration:
    name: Integration Tests
    runs-on: ubuntu-latest
    timeout-minutes: 15

    steps:
      - uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Install dependencies
        run: pip install -e .

      - name: Run integration tests
        run: pytest tests/integration/
EOF
)
        ;;

    go)
        WORKFLOW_CONTENT=$(cat <<'EOF'
name: Integration Tests

on:
  push:
    branches: [main, master]
  pull_request:
    branches: [main, master]

jobs:
  integration:
    name: Integration Tests
    runs-on: ubuntu-latest
    timeout-minutes: 15

    steps:
      - uses: actions/checkout@v4

      - name: Setup Go
        uses: actions/setup-go@v5
        with:
          go-version: '1.21'

      - name: Run integration tests
        run: go test ./tests/integration/...
EOF
)
        ;;

    *)
        # Generic fallback workflow
        WORKFLOW_CONTENT=$(cat <<'EOF'
name: Integration Tests

on:
  push:
    branches: [main, master]
  pull_request:
    branches: [main, master]

jobs:
  integration:
    name: Integration Tests
    runs-on: ubuntu-latest
    timeout-minutes: 15

    steps:
      - uses: actions/checkout@v4

      - name: Run integration tests
        run: |
          if [ -f Makefile ] && grep -q test Makefile; then
            make test
          elif [ -f package.json ]; then
            npm ci && npm run test:integration
          fi
EOF
        ;;
    esac

# Create the workflow file
mkdir -p "$(dirname "$TARGET_PATH")"
cat > "$TARGET_PATH" <<EOF
# Auto-generated by open-looper scaffold-integration-ci
$WORKFLOW_CONTENT
EOF

chmod +x "$TARGET_PATH" 2>/dev/null || true

echo "[scaffold-integration-ci] Created $TARGET_PATH" >&2
exit 0