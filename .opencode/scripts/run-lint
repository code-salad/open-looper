#!/usr/bin/env bash
set -euo pipefail

# run-lint — Run the project's linter
# Usage: run-lint [--fix]

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/_helpers.sh"

FIX=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --fix) FIX=true; shift ;;
        *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
done

STACK=$(load_stack)
linter=$(echo "$STACK" | jq -r '.linter')
# shellcheck disable=SC2034
package_manager=$(echo "$STACK" | jq -r '.package_manager')

case "$linter" in
    eslint)
        args=(".")
        [ "$FIX" = true ] && args+=("--fix")
        if has_pkg_script lint; then
            if [ "$FIX" = true ]; then
                run_pkg_script lint --fix
            else
                run_pkg_script lint
            fi
        else
            npx eslint "${args[@]}"
        fi
        ;;
    biome)
        args=("lint" ".")
        [ "$FIX" = true ] && args+=("--fix")
        npx biome "${args[@]}"
        ;;
    ruff)
        args=("check" ".")
        [ "$FIX" = true ] && args+=("--fix")
        run_python_tool ruff "${args[@]}"
        ;;
    flake8)
        run_python_tool flake8 .
        ;;
    golangci-lint)
        args=("run")
        [ "$FIX" = true ] && args+=("--fix")
        golangci-lint "${args[@]}"
        ;;
    go-vet)
        go vet ./...
        ;;
    clippy)
        cargo clippy -- -D warnings
        ;;
    dotnet-format)
        args=("format" "--verify-no-changes")
        [ "$FIX" = true ] && args=("format")
        dotnet "${args[@]}"
        ;;
    none)
        echo "No linter detected." >&2
        exit 1
        ;;
    *)
        echo "Unsupported linter: $linter" >&2
        exit 1
        ;;
esac
