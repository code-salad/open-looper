#!/usr/bin/env bash
set -euo pipefail

# run-tests — Run the project's test suite
# Usage: run-tests [--file <path>] [--grep <pattern>]

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/_helpers.sh"

FILE=""
GREP_PATTERN=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --file) FILE="$2"; shift 2 ;;
        --grep) GREP_PATTERN="$2"; shift 2 ;;
        *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
done

STACK=$(load_stack)
test_runner=$(echo "$STACK" | jq -r '.test_runner')
# shellcheck disable=SC2034
package_manager=$(echo "$STACK" | jq -r '.package_manager')

case "$test_runner" in
    vitest)
        args=("run")
        [ -n "$FILE" ] && args+=("$FILE")
        [ -n "$GREP_PATTERN" ] && args+=("--grep" "$GREP_PATTERN")
        if has_pkg_script test; then
            run_pkg_script test "${args[@]}"
        else
            npx vitest "${args[@]}"
        fi
        ;;
    jest)
        args=()
        [ -n "$FILE" ] && args+=("$FILE")
        [ -n "$GREP_PATTERN" ] && args+=("--testNamePattern" "$GREP_PATTERN")
        if has_pkg_script test; then
            run_pkg_script test "${args[@]}"
        else
            npx jest "${args[@]}"
        fi
        ;;
    mocha)
        args=()
        [ -n "$FILE" ] && args+=("$FILE")
        [ -n "$GREP_PATTERN" ] && args+=("--grep" "$GREP_PATTERN")
        if has_pkg_script test; then
            run_pkg_script test "${args[@]}"
        else
            npx mocha "${args[@]}"
        fi
        ;;
    pytest)
        args=()
        [ -n "$FILE" ] && args+=("$FILE")
        [ -n "$GREP_PATTERN" ] && args+=("-k" "$GREP_PATTERN")
        run_python_tool pytest "${args[@]}"
        ;;
    go-test)
        args=("./...")
        [ -n "$FILE" ] && args=("$FILE")
        [ -n "$GREP_PATTERN" ] && args+=("-run" "$GREP_PATTERN")
        go test "${args[@]}"
        ;;
    cargo-test)
        args=()
        [ -n "$GREP_PATTERN" ] && args+=("$GREP_PATTERN")
        cargo test "${args[@]}"
        ;;
    dotnet-test)
        args=()
        [ -n "$GREP_PATTERN" ] && args+=("--filter" "$GREP_PATTERN")
        dotnet test "${args[@]}"
        ;;
    none)
        echo "No test runner detected." >&2
        exit 1
        ;;
    *)
        echo "Unsupported test runner: $test_runner" >&2
        exit 1
        ;;
esac
