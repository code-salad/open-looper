#!/usr/bin/env bash
set -euo pipefail

# sync-with-remote — Fetch and rebase onto default remote branch
# Usage: sync-with-remote
# Outputs key=value pairs to stdout. Logs to stderr.
# Exit codes:
#   0 = clean (already up-to-date or rebased successfully)
#   1 = conflicts (rebase paused, manual resolution needed)
#   2 = error (fetch failed, no remote, etc.)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/_helpers.sh"

# Guard against core.bare=true which would cause sync operations to fail
_GIT_DIR=$(git rev-parse --absolute-git-dir 2>/dev/null || true)
if [ -n "$_GIT_DIR" ]; then
    _CANDIDATE_ROOT="${_GIT_DIR%/.git}"
    if [ "$_CANDIDATE_ROOT" != "$_GIT_DIR" ]; then
        ensure_not_bare "$_CANDIDATE_ROOT"
    else
        ensure_not_bare "$(pwd)"
    fi
fi

# Fetch latest from origin
if ! git fetch origin 1>&2; then
    echo "[sync] ERROR: git fetch origin failed" >&2
    exit 2
fi

# Detect default branch
DEFAULT_BRANCH=$(gh repo view --json defaultBranchRef --jq '.defaultBranchRef.name' 2>/dev/null || true)

if [ -z "$DEFAULT_BRANCH" ]; then
    # Fallback: check for main or master on origin
    if git show-ref --quiet refs/remotes/origin/main; then
        DEFAULT_BRANCH="main"
    elif git show-ref --quiet refs/remotes/origin/master; then
        DEFAULT_BRANCH="master"
    else
        echo "[sync] ERROR: Could not determine default branch" >&2
        exit 2
    fi
fi

echo "DEFAULT_BRANCH=$DEFAULT_BRANCH"

# Check if rebase is needed
MERGE_BASE=$(git merge-base "origin/$DEFAULT_BRANCH" HEAD 2>/dev/null || true)
REMOTE_HEAD=$(git rev-parse "origin/$DEFAULT_BRANCH" 2>/dev/null || true)

if [ -z "$MERGE_BASE" ] || [ -z "$REMOTE_HEAD" ]; then
    echo "[sync] ERROR: Could not compute merge base" >&2
    exit 2
fi

if [ "$MERGE_BASE" = "$REMOTE_HEAD" ]; then
    echo "STATUS=up-to-date"
    echo "[sync] Already up to date with origin/$DEFAULT_BRANCH" >&2
    exit 0
fi

# Attempt rebase
echo "[sync] Rebasing onto origin/$DEFAULT_BRANCH..." >&2
if git rebase "origin/$DEFAULT_BRANCH" 1>&2 2>&1; then
    echo "STATUS=rebased"
    echo "[sync] Successfully rebased onto origin/$DEFAULT_BRANCH" >&2
    exit 0
else
    echo "STATUS=conflicts"
    echo "[sync] Rebase conflicts detected — resolution needed" >&2
    exit 1
fi
