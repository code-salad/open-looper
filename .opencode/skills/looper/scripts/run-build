#!/usr/bin/env bash
set -euo pipefail

# run-build — Build the project
# Usage: run-build

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/_helpers.sh"

STACK=$(load_stack)
build_tool=$(echo "$STACK" | jq -r '.build_tool')
# shellcheck disable=SC2034
package_manager=$(echo "$STACK" | jq -r '.package_manager')

case "$build_tool" in
    vite|webpack|esbuild|rollup|tsup|tsc)
        if has_pkg_script build; then
            run_pkg_script build
        else
            case "$build_tool" in
                vite)    npx vite build ;;
                webpack) npx webpack ;;
                esbuild) npx esbuild --bundle ;;
                rollup)  npx rollup -c ;;
                tsup)    npx tsup ;;
                tsc)     npx tsc ;;
            esac
        fi
        ;;
    go-build)
        go build ./...
        ;;
    cargo-build)
        cargo build
        ;;
    dotnet-build)
        dotnet build
        ;;
    none)
        # Try package.json build script as last resort
        if has_pkg_script build; then
            run_pkg_script build
        elif [ -f "Makefile" ] && grep -q "^build:" Makefile; then
            make build
        else
            echo "No build tool detected." >&2
            exit 1
        fi
        ;;
    *)
        echo "Unsupported build tool: $build_tool" >&2
        exit 1
        ;;
esac
