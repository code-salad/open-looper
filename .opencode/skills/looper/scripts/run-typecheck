#!/usr/bin/env bash
set -euo pipefail

# run-typecheck — Run the project's type checker
# Usage: run-typecheck

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/_helpers.sh"

STACK=$(load_stack)
type_checker=$(echo "$STACK" | jq -r '.type_checker')
package_manager=$(echo "$STACK" | jq -r '.package_manager')

# has_typecheck_script — Unique logic: checks typecheck, check, and type-check scripts
has_typecheck_script() {
    [ -f "package.json" ] && jq -e '.scripts.typecheck // .scripts.check // .scripts["type-check"]' package.json &>/dev/null
}

case "$type_checker" in
    tsc)
        if has_typecheck_script; then
            # Try typecheck, then check, then type-check
            if jq -e '.scripts.typecheck' package.json &>/dev/null; then
                run_pkg_script typecheck
            elif jq -e '.scripts["type-check"]' package.json &>/dev/null; then
                run_pkg_script type-check
            else
                run_pkg_script check
            fi
        else
            npx tsc --noEmit
        fi
        ;;
    mypy)
        run_python_tool mypy .
        ;;
    pyright)
        # pyright falls back to npx, not python -m, so custom dispatch
        if [ "$package_manager" = "uv" ]; then
            uv run pyright
        elif [ "$package_manager" = "poetry" ]; then
            poetry run pyright
        else
            npx pyright
        fi
        ;;
    go-vet)
        go vet ./...
        ;;
    cargo-check)
        cargo check
        ;;
    dotnet-build)
        dotnet build --no-restore
        ;;
    none)
        echo "No type checker detected." >&2
        exit 1
        ;;
    *)
        echo "Unsupported type checker: $type_checker" >&2
        exit 1
        ;;
esac
