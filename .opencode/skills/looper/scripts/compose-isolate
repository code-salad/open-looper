#!/usr/bin/env bash
set -euo pipefail

# compose-isolate — Generate docker-compose.looper.yml and .env.looper with
# remapped ports for worktree isolation.
#
# Usage: compose-isolate --task <TASK_NAME> [--compose-json <JSON>]
#
# Produces:
#   docker-compose.looper.yml — override file with remapped host ports
#   .env.looper               — connection strings using remapped ports
#
# Outputs JSON summary to stdout.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

TASK_NAME=""
COMPOSE_JSON=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --task) TASK_NAME="$2"; shift 2 ;;
        --compose-json) COMPOSE_JSON="$2"; shift 2 ;;
        *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
done

if [ -z "$TASK_NAME" ]; then
    echo "Usage: compose-isolate --task <TASK_NAME>" >&2
    exit 1
fi

# Get compose info
if [ -z "$COMPOSE_JSON" ]; then
    COMPOSE_JSON=$("$SCRIPT_DIR/detect-compose")
fi

compose_file=$(echo "$COMPOSE_JSON" | jq -r '.compose_file')
if [ "$compose_file" = "none" ]; then
    echo '{"status":"skipped","reason":"no compose file"}'
    exit 0
fi

# Compute base offset from task name (same formula as LOOPER_DEV_PORT)
BASE_OFFSET=$(( $(echo "$TASK_NAME" | cksum | cut -d' ' -f1) % 50000 ))

# Remap function: shift a port into isolated range
remap_port() {
    local original="$1"
    echo $(( (original + BASE_OFFSET) % 50000 + 10000 ))
}

# Build override YAML and env vars using jq to process the compose JSON
# shellcheck disable=SC2016
RESULT=$(echo "$COMPOSE_JSON" | jq -r --argjson offset "$BASE_OFFSET" '
    .services | to_entries
    | map(select(.value.has_build != true))  # exclude app services (have build context)
    | map({
        name: .key,
        image: .value.image,
        ports: (.value.ports | map({
            original_host: .host,
            container: .container,
            remapped_host: (((.host + $offset) % 50000) + 10000)
        }))
    })
')

# Generate docker-compose.looper.yml
{
    echo "# Auto-generated by looper compose-isolate — do not edit"
    echo "# Task: $TASK_NAME | Offset: $BASE_OFFSET"
    echo ""
    echo "services:"

    echo "$RESULT" | jq -r '.[] | "  \(.name):\n    ports:\n" + (
        .ports | map("      - \"\(.remapped_host):\(.container)\"") | join("\n")
    )' 2>/dev/null || true
} > docker-compose.looper.yml

# Generate .env.looper with connection strings
{
    echo "# Auto-generated by looper compose-isolate — do not edit"
    echo "# Task: $TASK_NAME"
    echo "COMPOSE_PROJECT_NAME=looper-${TASK_NAME}"

    echo "$RESULT" | jq -r '.[] |
        . as $svc |
        .ports[] |
        (
            if ($svc.image | test("postgres"; "i")) then
                "PGPORT=\(.remapped_host)\nDATABASE_URL=postgresql://postgres:postgres@localhost:\(.remapped_host)/postgres"
            elif ($svc.image | test("mysql|mariadb"; "i")) then
                "MYSQL_PORT=\(.remapped_host)\nDATABASE_URL=mysql://root:root@localhost:\(.remapped_host)/app"
            elif ($svc.image | test("redis"; "i")) then
                "REDIS_PORT=\(.remapped_host)\nREDIS_URL=redis://localhost:\(.remapped_host)"
            elif ($svc.image | test("mongo"; "i")) then
                "MONGO_PORT=\(.remapped_host)\nMONGODB_URL=mongodb://localhost:\(.remapped_host)"
            elif ($svc.image | test("rabbit"; "i")) then
                "AMQP_PORT=\(.remapped_host)\nRABBITMQ_URL=amqp://guest:guest@localhost:\(.remapped_host)"
            elif ($svc.image | test("elastic|opensearch"; "i")) then
                "ELASTICSEARCH_URL=http://localhost:\(.remapped_host)"
            else
                "# \($svc.name) port: \(.remapped_host) (original: \(.original_host))"
            end
        )
    ' 2>/dev/null || true
} > .env.looper

# Output summary
echo "$RESULT" | jq --arg task "$TASK_NAME" --argjson offset "$BASE_OFFSET" '{
    status: "isolated",
    task: $task,
    offset: $offset,
    override_file: "docker-compose.looper.yml",
    env_file: ".env.looper",
    services: (map({key: .name, value: {
        ports: (.ports | map({original: .original_host, remapped: .remapped_host, container: .container}))
    }}) | from_entries)
}'
